# Copy to .env.local and fill in for real (non-mock) runs.
# See README.md "Quickstart" for the free, fully offline alternative
# (FAL_MOCK=1 STORAGE_MOCK=1) which needs none of these.

# fal.ai API key — server-only, never exposed to the client (server-only
# import guard in lib/fal-registry.ts). Get one at https://fal.ai/dashboard/keys
FAL_KEY=

# Shared passcode required on every mutating request (POST /api/ops,
# POST /api/canvas, PUT /api/canvas/:id). Sent as the x-gm-passcode header.
# Fails CLOSED in production if unset; fails OPEN in local dev if unset.
APP_PASSCODE=

# Vercel Blob read/write token, used by @vercel/blob to persist canvas
# snapshot JSON (GET/PUT /api/canvas/:id). Auto-injected by Vercel when a
# Blob store is connected to the project — set manually only for local dev
# against a real store. Not needed with STORAGE_MOCK=1.
BLOB_READ_WRITE_TOKEN=
